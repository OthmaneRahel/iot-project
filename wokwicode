def lire_dht22(): 
    """Lit l'humidité. Retourne None si erreur.""" 
    try: 
        capteur_dht.measure()
        humidite = capteur_dht.humidity()
        temperature = capteur_dht.temperature()
        return humidite,temperature
    except OSError as e: 
        print(f"Erreur DHT22 : {e}") 
        return None
